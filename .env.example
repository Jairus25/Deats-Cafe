# ─── SERVER ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── FRONTEND ─────────────────────────────────────────────
# In production set to your actual domain, e.g. https://deatscafe.in
FRONTEND_URL=http://localhost:5000

# ─── EMAIL (Nodemailer) ───────────────────────────────────
# Use Gmail App Password, SendGrid, Brevo etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
ADMIN_EMAIL=owner@deatscafe.in

# ─── DATABASE (for future MongoDB integration) ────────────
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/deatscafe

# ─── SECURITY ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-very-long-random-secret-string

# ─── ADMIN ────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=DeatsAdmin2025!
